<script>
function etfShowForm(plan, label, price) {
    document.getElementById('etf-plan-input').value = plan;
    document.getElementById('etf-plan-label').textContent = 'Selected: ' + label + ' — ' + price + '/month';
    document.getElementById('etf-pay-btn').textContent = 'Pay ' + price + ' with Stripe';
    document.getElementById('etf-form').classList.add('show');
    document.getElementById('etf-form').scrollIntoView({behavior:'smooth', block:'center'});
}

document.getElementById('etf-form').addEventListener('submit', function(e){
    e.preventDefault();
    const form = e.target;
    const errBox = document.getElementById('etf-err');
    errBox.style.display = 'none';
    const fd = new FormData(form);
    fetch(form.action, {method:'POST', body: fd})
        .then(r => r.json())
        .then(data => {
            if (data.url) {
                window.location.href = data.url;
            } else {
                errBox.textContent = data.error || 'Unknown error';
                errBox.style.display = 'block';
            }
        })
        .catch(err => {
            errBox.textContent = 'Network error: ' + err.message;
            errBox.style.display = 'block';
        });
});
</script>
